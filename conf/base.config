// ========================================================================================
//  Base resource labels - referenced from each module via `label '...'`
//  Tune these to your HPC.  Defaults are conservative for the zurada cpu384g partition.
// ========================================================================================

process {

    // Sane global defaults
    cpus          = 2
    memory        = 8.GB
    time          = 4.h
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 2

    // ----- resource labels -----
    withLabel: 'process_low' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }

    withLabel: 'process_medium' {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }

    withLabel: 'process_high' {
        cpus   = 16
        memory = 32.GB
        time   = 8.h
    }

    withLabel: 'process_high_memory' {
        cpus   = 8
        memory = 64.GB     // Kraken2 standard / PlusPF DBs need lots of RAM
        time   = 6.h
    }

    // ----- per-process overrides -----
    withName: 'MINIMAP2_MAP' {
        // Keep mapping fan-out reasonable: samples × references can explode
        maxForks = 16
    }

    withName: 'KRAKEN2' {
        // PlusPF DB ≈ 80 GB on disk; loaded into memory mostly
        memory = 80.GB
    }

    withName: 'MULTIQC' {
        // MultiQC just reads files, doesn't need a beefy node
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }

    withName: 'SAMPLE_REPORT' {
        cpus   = 1
        memory = 2.GB
        time   = 30.m
    }
}
