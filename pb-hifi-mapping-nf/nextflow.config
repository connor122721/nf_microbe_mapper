// ========================================================================================
//  pb-hifi-mapping-nf  -  configuration
//  Author : Connor S. Murray, PhD  (Univ. of Louisville SOM)
//  Adapted from the zurada HPC config style
// ========================================================================================

// ----------------------------------------------------------------------------------------
// PARAMS - all overridable from the command line (--<name> value)
// ----------------------------------------------------------------------------------------
params {

    help = false

    // Required
    samplesheet  = null
    references   = null

    // Taxonomy
    kraken2_db          = null
    run_bracken         = true
    bracken_read_length = 10000     // HiFi typical
    bracken_level       = 'S'       // species
    bracken_threshold   = 10

    // Minimap2
    minimap2_preset = 'map-hifi'    // PacBio HiFi/CCS preset
    minimap2_args   = ''            // anything extra (e.g. '--secondary=no')

    // Output
    outdir            = './results'
    publish_dir_mode  = 'copy'      // copy | link | symlink

    // SLURM defaults (override on command line for non-zurada systems)
    partition = 'cpu384g'

    // Container registry overrides (rarely needed - the modules ship sensible defaults)
    // Set to 'null' to use the in-module default; set to a SIF path / image to override.
    fastqc_container    = null
    minimap2_container  = null
    kraken2_container   = null
    bracken_container   = null
    multiqc_container   = null
    python_container    = null
}

// ----------------------------------------------------------------------------------------
// BASE PROCESS RESOURCES  (label-based)
// ----------------------------------------------------------------------------------------
includeConfig 'conf/base.config'

// ----------------------------------------------------------------------------------------
// PROFILES
// ----------------------------------------------------------------------------------------
profiles {

    // ----- container runtimes -----
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "$HOME/.singularity/cache"}"
        docker.enabled         = false
        apptainer.enabled      = false
        podman.enabled         = false
    }

    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        apptainer.cacheDir   = "${System.getenv('NXF_APPTAINER_CACHEDIR') ?: "$HOME/.apptainer/cache"}"
        singularity.enabled  = false
        docker.enabled       = false
        podman.enabled       = false
    }

    docker {
        docker.enabled      = true
        docker.userEmulation = true
        singularity.enabled = false
        apptainer.enabled   = false
        podman.enabled      = false
    }

    podman {
        podman.enabled      = true
        singularity.enabled = false
        apptainer.enabled   = false
        docker.enabled      = false
    }

    // ----- executors -----
    local {
        process.executor = 'local'
    }

    slurm {
        executor {
            name           = 'slurm'
            queueSize      = 25
            submitRateLimit = '8/1min'
        }
        process {
            executor       = 'slurm'
            clusterOptions = "--partition=${params.partition} --oversubscribe"
        }
    }

    // ----- convenience profiles -----
    test {
        includeConfig 'conf/test.config'
    }

    debug {
        process.beforeScript = 'echo $HOSTNAME && nproc'
        cleanup              = false
        dumpHashes           = true
    }
}

// ----------------------------------------------------------------------------------------
// CONTAINER OVERRIDE PLUMBING - applies user-overrides on top of module defaults
// ----------------------------------------------------------------------------------------
process {
    withName: 'FASTQC'        { if (params.fastqc_container)   container = params.fastqc_container }
    withName: 'MINIMAP2_MAP'  { if (params.minimap2_container) container = params.minimap2_container }
    withName: 'KRAKEN2'       { if (params.kraken2_container)  container = params.kraken2_container }
    withName: 'BRACKEN'       { if (params.bracken_container)  container = params.bracken_container }
    withName: 'MULTIQC'       { if (params.multiqc_container)  container = params.multiqc_container }
    withName: 'SAMPLE_REPORT' { if (params.python_container)   container = params.python_container }
}

// ----------------------------------------------------------------------------------------
// MANIFEST
// ----------------------------------------------------------------------------------------
manifest {
    name            = 'pb-hifi-mapping-nf'
    author          = 'Connor S. Murray, PhD'
    homePage        = 'https://github.com/<your-org>/pb-hifi-mapping-nf'
    description     = 'Parallel minimap2 mapping + QC + taxonomic profiling for PacBio HiFi reads'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '0.1.0'
}

// ----------------------------------------------------------------------------------------
// PIPELINE REPORTS
// ----------------------------------------------------------------------------------------
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.tsv"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,realtime,%cpu,rss,duration,start,complete'
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}

// ----------------------------------------------------------------------------------------
// SHELL DEFAULTS - safer
// ----------------------------------------------------------------------------------------
process.shell = ['/bin/bash', '-euo', 'pipefail']
