// ========================================================================================
//  Tiny smoke-test profile.
//
//  Usage:
//    nextflow run main.nf -profile test,docker
//    nextflow run main.nf -profile test,singularity
//
//  By default it points at a samplesheet+references inside `assets/test/` that you
//  must drop in yourself (small enough to fit in the repo, e.g. a 1k-read subset
//  + a single small reference like phiX).  See `docs/test_data.md`.
// ========================================================================================

params {
    samplesheet = "${projectDir}/assets/test/samplesheet.test.csv"
    references  = "${projectDir}/assets/test/refs/*.fa.gz"

    // Skip taxonomy in CI by default (no DB available)
    kraken2_db  = null
    run_bracken = false

    outdir      = "${projectDir}/test_results"
}

process {
    executor      = 'local'
    cpus          = 2
    memory        = 4.GB
    time          = 30.m
    errorStrategy = 'terminate'

    withLabel: 'process_high'        { cpus = 2; memory = 4.GB }
    withLabel: 'process_high_memory' { cpus = 2; memory = 4.GB }
    withLabel: 'process_medium'      { cpus = 2; memory = 4.GB }
    withLabel: 'process_low'         { cpus = 1; memory = 2.GB }
}
